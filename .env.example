# ─── Email OTP (need at least one provider) ─────────────────────────────────
# Option A — Resend (https://resend.com): create API key, verify domain or use onboarding@resend.dev
RESEND_API_KEY=
# Optional; avoid raw gmail.com as From unless verified on Resend
RESEND_FROM=Mineral Bridge <onboarding@resend.dev>

# Option B — SMTP (Gmail: use App Password, not account password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraccount@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=youraccount@gmail.com

# Emergency local testing when NODE_ENV=production and no mail provider (logs OTP to server console — remove for real production)
# EMAIL_OTP_DEV_LOG=1
