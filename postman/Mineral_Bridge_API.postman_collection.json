{
  "info": {
    "name": "Mineral Bridge API",
    "description": "All backend endpoints for testing. Run 1–3 (Auth) first to get token, then use it in other requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "0. Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "1. Auth (get token first)",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"+1\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/send-otp"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"+1\",\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/verify-otp"
          }
        },
        {
          "name": "Register or Login (save token from response)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"+1\",\n  \"phone\": \"9876543210\",\n  \"name\": \"Test User\",\n  \"email\": \"test@mineralbridge.com\",\n  \"location\": { \"lat\": 9.0, \"lng\": 38.7 }\n}"
            },
            "url": "{{baseUrl}}/api/auth/register-or-login"
          }
        }
      ]
    },
    {
      "name": "2. Public (no auth)",
      "item": [
        {
          "name": "Minerals List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/minerals"
          }
        },
        {
          "name": "Minerals List by category",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/minerals?category=Precious Metals"
          }
        },
        {
          "name": "Mineral by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/minerals/gold"
          }
        },
        {
          "name": "Market Insights",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/market-insights"
          }
        },
        {
          "name": "Help FAQs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/help/faqs"
          }
        },
        {
